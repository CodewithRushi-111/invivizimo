                  "pm.test(\"Response returns JWT and user profile\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.data.accessToken).to.exist;",
                  "    pm.environment.set(\"accessToken\", json.data.accessToken);",
                  "    pm.environment.set(\"tokenExpiry\", Date.now() + 14 * 60 * 1000); // 14 mins",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"testuser@example.com\",\n    \"password\": \"securepassword123\"\n}"
